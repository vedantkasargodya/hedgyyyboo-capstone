# Hedgyyyboo backend — example environment variables.
# Copy this to `.env` (same directory) and fill in real values.
# .env is gitignored and MUST NOT be committed.

# OpenRouter — free Gemma-3n-E4B-it inference. Create a key at
# https://openrouter.ai/keys and paste it here.
OPENROUTER_API_KEY=sk-or-v1-your_new_key_here

# Trade-ledger database. SQLite works for single-user dev.
# For PostgreSQL use e.g.  postgresql://user:pass@localhost:5432/hedgyyyboo
DATABASE_URL=sqlite:///hedgyyyboo_trades.db
