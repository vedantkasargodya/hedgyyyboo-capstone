# Secrets — never commit
.env
backend/.env
*.env.local
*.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
venv_new/
env/
.venv
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node / Next.js
node_modules/
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo
next-env.d.ts

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Databases — keep the schema, don't commit the data
*.db-journal
*.db-shm
*.db-wal

# Word / Office lock files when doc is open
~$*.docx
~$*.doc
~$*.xlsx

# Model weights (too big)
*.safetensors
*.bin
*.pth
models/
embeddings_cache/

# Per-user caches
backend/qdrant_storage/
backend/.ruff_cache/
